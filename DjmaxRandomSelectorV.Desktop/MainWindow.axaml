<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DjmaxRandomSelectorV.Desktop.MainWindow"
        Title="DJMAX Random Selector V"
        Width="480" Height="380"
        CanResize="False"
        WindowStartupLocation="CenterScreen">
    <Border Padding="24">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Spacing="2">
                <TextBlock Text="DJMAX Random Selector V"
                           FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="macOS port — preview build"
                           Opacity="0.6" FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Spacing="8">
                <Button x:Name="SelectButton"
                        Content="🎲  Select random  (F7 in-game)"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="0,12" />
                <Button x:Name="AccessibilityButton"
                        Content="⚠︎  Grant Accessibility permission"
                        IsVisible="False"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="0,10" />
                <TextBlock x:Name="StatusText"
                           FontSize="11" Opacity="0.6"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>

            <Border Margin="0,18"
                    Background="#22FFFFFF" CornerRadius="8" Padding="18"
                    VerticalAlignment="Center">
                <StackPanel Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="SELECTED"
                               FontSize="11" Opacity="0.5"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="TitleText"
                               Text="—"
                               FontSize="20" FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock x:Name="ComposerText"
                               Text=""
                               Opacity="0.75"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock x:Name="PatternText"
                               Text=""
                               Opacity="0.9"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </DockPanel>
    </Border>
</Window>
